# ─── LLM Configuration (Required) ───
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# ─── Extraction Model (Optional — separate fast model for data extraction) ───
# EXTRACTION_MODEL=meta/llama-3.1-8b-instruct
# EXTRACTION_API_KEY=nvapi-...
# EXTRACTION_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Browser Configuration (Optional) ───
# BROWSER_HEADLESS=true
# BROWSER_USER_DATA_DIR=/path/to/profile

# ─── Proxy (Optional) ───
# HTTP_PROXY=http://proxy.example.com:8080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass

# ─── Legacy Support ───
# OPENAI_API_KEY=sk-...
