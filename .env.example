# LLM API Keys (Required for AI perception logic)
# You can use OpenAI or an equivalent API
OPENAI_API_KEY=your_openai_api_key_here
# Go-WebMCP uses AI_API_KEY by default
AI_API_KEY=your_openai_api_key_here

# For stealth adjustments (optional)
# HTTP_PROXY=http://user:pass@proxy...

# --- Authentication for E2E Tests ---

# LinkedIn Verification
LINKEDIN_USERNAME=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Twitter Verification
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Reddit Verification
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
