{
    "youtube.video_title": {
        "selector": "h1.ytd-watch-metadata yt-formatted-string",
        "fallback": "#title h1",
        "extract": [
            "innerText"
        ],
        "tags": [
            "read",
            "core",
            "extract",
            "data"
        ]
    },
    "youtube.channel_name": {
        "selector": "#channel-name yt-formatted-string a",
        "fallback": "ytd-channel-name a",
        "extract": [
            "innerText"
        ],
        "tags": [
            "read",
            "core",
            "extract",
            "data"
        ]
    },
    "youtube.view_count": {
        "selector": "ytd-watch-info-text span.bold:first-of-type",
        "fallback": "#info-strings yt-formatted-string",
        "extract": [
            "innerText"
        ],
        "tags": [
            "read",
            "core",
            "extract",
            "data"
        ]
    },
    "youtube.search_box": {
        "selector": "input#search",
        "fallback": "input[name='search_query']",
        "tags": [
            "core",
            "search",
            "query"
        ]
    },
    "youtube.first_result": {
        "selector": "ytd-video-renderer:first-of-type a#video-title",
        "extract": [
            "innerText",
            "href"
        ],
        "tags": [
            "read",
            "core",
            "extract",
            "data"
        ]
    },
    "youtube.first_comment": {
        "selector": "ytd-comment-thread-renderer:first-of-type #content-text",
        "extract": [
            "innerText"
        ],
        "tags": [
            "read",
            "data",
            "write",
            "core",
            "extract",
            "content"
        ]
    }
}