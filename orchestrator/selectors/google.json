    "google.first_reddit_link": {
        "script": "(() => { function getRealUrl(h) { if(!h) return ''; if(!h.includes('/url?q=')) return h; try { const u = new URL(h.startsWith('/') ? `https://www.google.com${h}` : h); return decodeURIComponent(u.searchParams.get('q') || ''); } catch(e) { const m = h.match(/q=([^&]+)/); return m ? decodeURIComponent(m[1]) : h; } } const a = Array.from(document.querySelectorAll('a')).find(el => { const href = el.getAttribute('href'); if(!href) return false; const realUrl = getRealUrl(href); return realUrl.includes('reddit.com') && el.querySelector('h3'); }); return JSON.stringify(a ? { url: getRealUrl(a.getAttribute('href')) } : { error: 'Not found' }); })()",
        "notes": "Extracts the exact URL of the first Reddit result on Google. Parses the /url?q= parameter to bypass Google click-tracking.",
        "tags": [
            "interact",
            "core",
            "navigate"
        ]
    },
